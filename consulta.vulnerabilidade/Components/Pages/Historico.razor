@page "/historico"
@using consulta.vulnerabilidade.Domain.Scans
@using consulta.vulnerabilidade.Application.Abstractions
@inject IScanReportRepository Repo

<HistoricoContent IsLoading="@_isLoading"
                  Error="@_error"
                  Reports="@_recent"
                  OnDelete="OnDelete" />

@code {
    bool _isLoading = true;
    string? _error;
    IReadOnlyList<ScanReport> _recent = Array.Empty<ScanReport>();

    protected override async Task OnInitializedAsync()
    {
        await LoadRecentAsync();
    }

    async Task LoadRecentAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            _recent = await Repo.GetRecentAsync(10);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    async Task OnDelete(string url)
    {
        try
        {
            await Repo.DeleteByUrlAsync(url);
            await LoadRecentAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
