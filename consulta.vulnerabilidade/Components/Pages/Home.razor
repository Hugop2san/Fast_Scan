@rendermode InteractiveServer
@page "/"
@using consulta.vulnerabilidade.Domain.Scans
@using consulta.vulnerabilidade.Application.Scans
@using consulta.vulnerabilidade.Application.Abstractions
@inject ScanDispatcher Dispatcher
@inject IScanReportRepository Repo

<div class="home-page-shell" style="@PageShellStyle">
<div class="container home-center-shell @(_darkMode ? "home-mode-dark" : string.Empty)" style="@HomeContainerStyle">

    <div class="home-hero">
        <div class="home-theme-toggle form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   role="switch"
                   id="homeThemeSwitch"
                   @bind="_darkMode" />
            <label class="form-check-label" for="homeThemeSwitch">Modo escuro</label>
        </div>

        <div class="scan-container scan-input-row mb-3"
             style="max-width:700px; margin:auto; margin-top:80px;">
            <div class="input-group futuristic-search"
                 style="display:flex; width:100%; border-radius:20px; overflow:visible; gap:10px;">
                <input type="text"
                       class="form-control futuristic-input"
                       style="@InputStyle"
                       placeholder="https://example.com"
                       @bind="_url" />
                <button class="btn futuristic-btn"
                        style="@ButtonStyle"
                        @onclick="OnAnalyze">
                    Start Scan
                </button>
            </div>
        </div>

        <p class="text-muted mb-4 home-helper-text text-center" style="@HelperTextStyle">
            Cole uma URL e receba um checklist de hardening + explicação (leigo + técnico).
        </p>
    </div>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="alert alert-secondary" style="@StatusAlertStyle">
            <strong>Status:</strong> @_status
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger" style="@ErrorAlertStyle">
            <strong>Erro:</strong> @_error
        </div>
    }

    @if (_isLoading)
    {
        <div class="alert alert-info" style="@InfoAlertStyle">Analisando... (MVP: aguarde finalizar)</div>
    }

    @if (_lastReport is not null)
    {
        <div class="card p-3" style="@ResultCardStyle">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0">Resultado</h5>
                    <small class="text-muted" style="@HelperTextStyle">@_lastReport!.Url • @_lastReport!.CreatedAt.ToLocalTime()</small>
                </div>
                <span class="badge bg-primary">Score: @_lastReport.Score/100</span>
            </div>

            <hr />

            @if (_lastReport.Findings.Count == 0)
            {
                <div class="alert alert-success mb-0">Nenhum achado relevante (pelo scanner MVP).</div>
            }
            else
            {
                @foreach (var f in _lastReport.Findings.Where(x => x.Title != "OK"))
                {
                    <div class="mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge @SeverityBadge(f.Severity)">@f.Severity</span>
                            <strong>@f.Title</strong>
                        </div>
                        <div class="text-muted">@f.Explanation</div>

                        @if (!string.IsNullOrWhiteSpace(f.TechnicalDetails))
                        {
                            <details class="mt-1">
                                <summary>Detalhes técnicos</summary>
                                <pre class="mb-0">@f.TechnicalDetails</pre>
                            </details>
                        }
                    </div>
                }
            }
        </div>
    }

</div>
</div>




@code {
    string _url = "";
    bool _useAi = false;

    bool _isLoading = false;

    string? _status;
    string? _error;

    ScanReport? _lastReport;
    bool _darkMode = false;

    string PageShellStyle => _darkMode
        ? "background:#0f172a; color:#e5eefb; min-height:calc(100vh - 3.5rem); padding:1.5rem 0 3rem; transition:background-color .2s ease,color .2s ease;"
        : "background:transparent; color:inherit; min-height:calc(100vh - 3.5rem); padding:1.5rem 0 3rem; transition:background-color .2s ease,color .2s ease;";

    string HomeContainerStyle => _darkMode
        ? "background:#0f172a; color:#e5eefb; border-radius:24px; box-shadow:0 20px 45px rgba(15,23,42,.22);"
        : "background:transparent; color:inherit; border-radius:24px; box-shadow:none;";

    string InputStyle => _darkMode
        ? "background:#162033; border:2px solid #38bdf8; color:#f8fafc; padding:18px 20px; font-size:18px; border-radius:20px 0 0 20px; box-shadow:none;"
        : "background:#0f172a; border:2px solid #38bdf8; color:white; padding:18px 20px; font-size:18px; border-radius:20px 0 0 20px; box-shadow:none;";

    string ButtonStyle => "background:linear-gradient(45deg,#06b6d4,#3b82f6); border:none; padding:18px 28px; font-size:18px; font-weight:600; border-radius:0 20px 20px 0; color:white; white-space:nowrap;";

    string HelperTextStyle => _darkMode ? "color:#cbd5e1 !important;" : string.Empty;

    string StatusAlertStyle => _darkMode
        ? "background:#1e293b; color:#e5eefb; border-color:rgba(148,163,184,.22);"
        : string.Empty;

    string ErrorAlertStyle => _darkMode
        ? "background:#3f1d1d; color:#ffe4e6; border-color:rgba(248,113,113,.28);"
        : string.Empty;

    string InfoAlertStyle => _darkMode
        ? "background:#082f49; color:#e0f2fe; border-color:rgba(56,189,248,.32);"
        : string.Empty;

    string ResultCardStyle => _darkMode
        ? "background:#111827; color:#e5eefb; border-color:rgba(148,163,184,.18);"
        : string.Empty;

    async Task OnAnalyze()
    {
        _error = null;
        _status = "Clique recebido no botão Analisar.";

        if (string.IsNullOrWhiteSpace(_url))
        {
            _status = "Fluxo interrompido: URL vazia.";
            return;
        }

        _isLoading = true;
        _lastReport = null;
        _status = $"Iniciando análise para URL: {_url}";
        StateHasChanged();

        try
        {
            _status = "Chamando Dispatcher.RequestScanAsync...";
            var scanId = await Dispatcher.RequestScanAsync(_url, _useAi);

            _status = $"Scan solicitado com sucesso. Id: {scanId}";
            StateHasChanged();

            _status = "Buscando último relatório...";
            _lastReport = await Repo.GetLastAsync(_url);

            if (_lastReport is null)
            {
                _status = "Scan executado, mas Repo.GetLastAsync não retornou relatório.";
            }
            else
            {
                _status = $"Relatório encontrado para {_lastReport.Url} com score {_lastReport.Score}.";
            }

        }
        catch (Exception ex)
        {
            _error = ex.ToString();
            _status = "A análise falhou com exceção.";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    static string SeverityBadge(string s) => s switch
    {
        "HIGH" => "bg-danger",
        "MEDIUM" => "bg-warning text-dark",
        "LOW" => "bg-secondary",
        _ => "bg-light text-dark"
    };
}
