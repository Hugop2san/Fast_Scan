@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar" style="display: @(_hideMenu ? "none" : "block");">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4" style="background-color: rgba(0,0,0,0.4); border-bottom: 1px solid rgba(255,255,255,0.12);">
            <div class="top-row-left">
                <button class="menu-toggle" title="Mostrar/Ocultar menu" @onclick="ToggleMenu">&#9776;</button>
            </div>

            <div class="top-row-right">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" style="color: #fff;">About</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>

@code {
    private bool _hideMenu = true;

    private void ToggleMenu() => _hideMenu = !_hideMenu;
}
