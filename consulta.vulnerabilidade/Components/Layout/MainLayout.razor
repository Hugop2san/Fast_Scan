@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar" style="display: @(_hideMenu ? "none" : "block"); background-color:#162033 !important; background-image:none !important;">
        <NavMenu />
    </div>

    <main>
        <header class="app-topbar px-4 navbar navbar-dark" style="background-color:#162033 !important; background-image:none !important; border-bottom: 1px solid rgba(255,255,255,0.14);">
            <div class="app-topbar-left">
                <button class="menu-toggle" title="Mostrar/Ocultar menu" @onclick="ToggleMenu">&#9776;</button>
            </div>

            <div class="app-topbar-right">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" style="color: #fff;">About</a>
            </div>
        </header>
        <article class="content px-4 py-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>

@code {
    private bool _hideMenu = true;

    private void ToggleMenu() => _hideMenu = !_hideMenu;
}

