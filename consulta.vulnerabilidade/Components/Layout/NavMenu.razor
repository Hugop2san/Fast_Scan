<div class="navmenu-shell @(IsCollapsed ? "collapsed" : string.Empty)">
    <div class="nav-scrollable" style="background-color:#162033 !important; background-image:none !important;">
        <nav class="flex-column nav-links">
            <div class="nav-top-spacer" aria-hidden="true"></div>

            <div class="nav-item px-3" style="@GetItemContainerStyle()">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All" style="@GetLinkStyle()">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true" style="@GetIconStyle()"></span>
                    <span class="nav-label" style="@GetLabelStyle()">Home</span>
                </NavLink>
            </div>

            <div class="nav-item px-3" style="@GetItemContainerStyle()">
                <NavLink class="nav-link" href="historico" style="@GetLinkStyle()">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true" style="@GetIconStyle()"></span>
                    <span class="nav-label" style="@GetLabelStyle()">Historico</span>
                </NavLink>
            </div>
        </nav>

        <div class="nav-footer-brand navbar navbar-dark " style="background-color:#162033 !important; background-image:none !important;">
            <div class="container-fluid">
                <a class="navbar-brand ms-5" href="" style="@GetBrandStyle()"><h2>Fast Scan</h2></a>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }

    private string GetBrandStyle() =>
        IsCollapsed ? "display:none;" : string.Empty;

    private string GetItemContainerStyle() =>
        IsCollapsed ? "padding-left:.45rem !important; padding-right:.45rem !important;" : string.Empty;

    private string GetLinkStyle() =>
        IsCollapsed ? "justify-content:center;" : string.Empty;

    private string GetIconStyle() =>
        IsCollapsed ? "margin-right:0;" : string.Empty;

    private string GetLabelStyle() =>
        IsCollapsed
            ? "opacity:0; max-width:0; overflow:hidden; display:inline-block;"
            : "opacity:1; max-width:150px; display:inline-block;";
}
